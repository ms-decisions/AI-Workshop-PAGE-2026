<DATAFILE>

[FILEINFO]
file='../derived-data/ds-sglt2-pd-fit-dapa.csv'
delimiter = comma
header={ID, TIME, DV, DVID, DVNAME, ADM, CMT, MDV, EVID, AMT, DOSE, GFR, MPGinitial, kt2d}

[CONTENT]
ID = {use=identifier}
TIME = {use=time}
DV = {use=observation, yname='1', type=continuous}
DVID = {use=observationtype}
ADM = {use=administration}
MDV = {use=missingdependentvariable}
EVID = {use=eventidentifier}
AMT = {use=amount}
DOSE = {use=covariate, type=categorical}
GFR = {use=regressor}
MPGinitial = {use=regressor}
kt2d = {use=regressor}

[SETTINGS]
dataType = {'1'=plasma}

<MODEL>

[COVARIATE]
input = DOSE

DOSE = {type=categorical, categories={'1', '10', '100', '2.5', '20', '25', '5', '50'}}

[INDIVIDUAL]
input = {VmaxreabsSGLT2hs_pop, VmaxreabsSGLT2t2d_pop}

DEFINITION:
VmaxreabsSGLT2hs = {distribution=logNormal, typical=VmaxreabsSGLT2hs_pop, no-variability}
VmaxreabsSGLT2t2d = {distribution=logNormal, typical=VmaxreabsSGLT2t2d_pop, no-variability}

[LONGITUDINAL]
input = {b}

file = '../models/model-sglt2-mlxtran-simp.txt'

DEFINITION:
y1 = {distribution=normal, prediction=UGE, errorModel=proportional(b)}

<FIT>
data = '1'
model = y1

<PARAMETER>
VmaxreabsSGLT2hs_pop = {value=85, method=MLE}
VmaxreabsSGLT2t2d_pop = {value=112, method=MLE}
b = {value=0.3, method=MLE}
c = {value=1, method=FIXED}

<MONOLIX>

[TASKS]
populationParameters()
individualParameters(method = conditionalMode)
fim(method = StochasticApproximation)
logLikelihood(method = ImportanceSampling)
plotResult(method = {indfits, parameterdistribution, covariancemodeldiagnosis, covariatemodeldiagnosis, obspred, residualsscatter, residualsdistribution, randomeffects, saemresults })

[SETTINGS]
GLOBAL:
exportpath = 'run1-sglt2-qsp'

